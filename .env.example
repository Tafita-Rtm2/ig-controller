# ═══════════════════════════════════════════
#  IGSubBot Server — Variables d'environnement
#  Copier en .env et remplir les valeurs
# ═══════════════════════════════════════════

# Token admin pour accéder au panel /admin
# Choisir quelque chose de fort !
ADMIN_TOKEN=rtm

# Mot de passe des sous-comptes créés
SUB_PASS=rtm

# Nombre de comptes à créer par appareil
SUBS_COUNT=10

# Hash SHA256 du bot autorisé (optionnel)
# Laisser vide pour désactiver la vérification
# Obtenir avec: python3 -c "import hashlib; ..."
BOT_HASHES=

# Port (Render le met automatiquement)
PORT=3000
